{
  "name": "cybercoder-cli",
  "version": "0.1.35",
  "description": "CyberCoder CLI — fullstack agentic coding assistant by Codeva",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cm": "./bin/cybermind.mjs",
    "codeva": "./bin/cybermind.mjs",
    "cybercoder": "./bin/cybermind.mjs"
  },
  "files": [
    "bin",
    "dist",
    "skills-bundled",
    "install.sh",
    "install.ps1",
    "install.cmd",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "bundle-skills": "node scripts/bundle-skills.mjs",
    "prebuild": "node scripts/bundle-skills.mjs",
    "build": "tsup",
    "build:rpc": "tsup src/rpc-entry.ts --format esm --target node20 --outDir dist/rpc --clean",
    "compile": "npm run build:rpc && node scripts/compile-binary.mjs",
    "compile:win": "npm run build && node scripts/compile-binary.mjs --target win",
    "compile:mac": "npm run build && node scripts/compile-binary.mjs --target mac",
    "compile:linux": "npm run build && node scripts/compile-binary.mjs --target linux",
    "prepublishOnly": "node scripts/bundle-skills.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo '(tests added in M14)'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "figures": "^6.1.0",
    "gradient-string": "^3.0.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}