{
  "name": "cybercoder-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "� CyberCoder CLI — Advanced AI-powered command-line interface, better than Claude Code",
  "homepage": "https://stilcybermindcli.github.io/cybercoder",
  "repository": {
    "type": "git",
    "url": "https://github.com/stilcybermindcli/cybercoder"
  },
  "license": "MIT",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev": "pnpm --filter @cybermind/cli run dev",
    "cli": "pnpm --filter @cybermind/cli run dev",
    "typecheck": "pnpm -r --parallel run typecheck",
    "lint": "pnpm -r --parallel run lint",
    "test": "pnpm -r --parallel run test",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
